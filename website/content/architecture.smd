---
.title = "Architecture",
.layout = "page.shtml",
.description = "Understand the architecture behind powerglide's multi-agent orchestration",
.author = "powerglide team",
.date = @date("2026-03-02"),
---

powerglide is built in [Zig 0.15.2](https://ziglang.org/) with a modular architecture designed for reliability and performance.

## Module Structure

```=html
<svg viewBox="0 0 700 520" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="pg-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F7A41D;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#d97706;stop-opacity:1"/>
    </linearGradient>
    <linearGradient id="cyan-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#06b6d4;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#0891b2;stop-opacity:1"/>
    </linearGradient>
    <linearGradient id="purple-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#6d28d9;stop-opacity:1"/>
    </linearGradient>
    <filter id="neon-glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur1"/>
      <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur2"/>
      <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="blur3"/>
      <feMerge>
        <feMergeNode in="blur3"/>
        <feMergeNode in="blur2"/>
        <feMergeNode in="blur1"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <filter id="soft-glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="700" height="520" fill="#050505" rx="8"/>

  <!-- Cyber grid pattern -->
  <g stroke="#1a1a25" stroke-width="1">
    <line x1="100" y1="0" x2="100" y2="520"/>
    <line x1="200" y1="0" x2="200" y2="520"/>
    <line x1="300" y1="0" x2="300" y2="520"/>
    <line x1="400" y1="0" x2="400" y2="520"/>
    <line x1="500" y1="0" x2="500" y2="520"/>
    <line x1="600" y1="0" x2="600" y2="520"/>
    <line x1="0" y1="100" x2="700" y2="100"/>
    <line x1="0" y1="200" x2="700" y2="200"/>
    <line x1="0" y1="300" x2="700" y2="300"/>
    <line x1="0" y1="400" x2="700" y2="400"/>
  </g>

  <!-- Title -->
  <text x="350" y="35" text-anchor="middle" fill="#F7A41D" font-size="18" font-weight="bold" font-family="monospace" filter="url(#neon-glow)">src/</text>

  <!-- Root node -->
  <rect x="280" y="55" width="140" height="35" fill="none" stroke="url(#pg-gradient)" stroke-width="2" rx="4" filter="url(#soft-glow)"/>
  <text x="350" y="78" text-anchor="middle" fill="#e4e4e7" font-size="14" font-family="monospace">main.zig</text>

  <!-- Vertical line from root -->
  <line x1="350" y1="90" x2="350" y2="115" stroke="url(#pg-gradient)" stroke-width="2"/>

  <!-- First-row horizontal bus -->
  <line x1="80" y1="115" x2="560" y2="115" stroke="url(#pg-gradient)" stroke-width="1.5"/>

  <!-- Trunk line to second row -->
  <line x1="350" y1="145" x2="350" y2="250" stroke="url(#cyan-gradient)" stroke-width="1.5" stroke-dasharray="4,3"/>

  <!-- Second-row horizontal bus -->
  <line x1="80" y1="250" x2="390" y2="250" stroke="url(#cyan-gradient)" stroke-width="1.5"/>

  <!-- Level 1 nodes -->
  <!-- agent/ -->
  <rect x="30" y="115" width="100" height="30" fill="none" stroke="url(#cyan-gradient)" stroke-width="2" rx="4" filter="url(#soft-glow)"/>
  <text x="80" y="135" text-anchor="middle" fill="#e4e4e7" font-size="12" font-family="monospace">agent/</text>

