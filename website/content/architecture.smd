  </g>

  <!-- ── ORCHESTRATOR PANEL (y=20–140) ── -->
  <rect x="20" y="20" width="640" height="120" fill="#0c0c14" stroke="#7c3aed" stroke-width="2" rx="6" filter="url(#sw-glow)"/>
  <text x="340" y="47" text-anchor="middle" fill="#a78bfa" font-size="15" font-weight="bold" font-family="monospace" filter="url(#sw-glow)">ORCHESTRATOR</text>
  <text x="340" y="64" text-anchor="middle" fill="#6d6d8a" font-size="10" font-family="monospace">slow, powerful model · routes tasks and aggregates results</text>
